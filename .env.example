# Primary free-tier provider: Google AI Studio.
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_MODEL=gemini-3.1-flash-lite

# Optional paid fallback. Leave blank unless you want OpenAI fallback behavior.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

ENABLE_CACHE=true
MAX_RETRIES=3
RETRY_DELAY_SEC=2.0
